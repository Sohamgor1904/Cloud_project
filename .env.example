# SmartWaste — Environment Variables
# Copy this file to .env and fill in real values
# NEVER commit .env to Git

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smartwaste
DB_USER=postgres
DB_PASSWORD=yourpassword

# Convenience full URL (alternative to individual vars above)
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/smartwaste

# Server
PORT=3000
NODE_ENV=development
